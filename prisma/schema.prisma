generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  description String
  price       String
  category    String
  image       String?
  imageAlt    String?
  featured    Boolean     @default(false)
  active      Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerEmail String
  customerPhone String?
  pickupTime    String
  notes         String?
  status        String      @default("new")
  totalAmount   Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  menuItemId String?
  name       String
  category   String
  unitPrice  Int
  quantity   Int
  lineTotal  Int
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  topic     String
  visitDate String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
